# ============================================================
# BOT TRIPLE CONFIRMACIÓN — Variables Railway
# ============================================================
# Copia esto en Railway → Variables → RAW Editor
# Rellena los 4 primeros con tus credenciales reales

BINGX_API_KEY=
BINGX_API_SECRET=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Trading ──────────────────────────────────────────────────
AUTO_TRADING_ENABLED=true
MAX_POSITION_SIZE=10
MIN_TRADE_USDT=5
LEVERAGE=5
TAKE_PROFIT_PCT=2.0
STOP_LOSS_PCT=1.0
MAX_OPEN_TRADES=3
TRAILING_STOP_ENABLED=true

# ── Dirección ────────────────────────────────────────────────
ENABLE_LONGS=true
ENABLE_SHORTS=true

# ── Filtros ──────────────────────────────────────────────────
MIN_SCORE=70
MIN_VOLUME_24H=500000
MAX_SYMBOLS_TO_ANALYZE=80
BTC_FILTER_PCT=2.0

# ── Operativa ────────────────────────────────────────────────
CHECK_INTERVAL=120
USE_LIMIT_ORDERS=true
