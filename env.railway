# ══════════════════════════════════════════════════════════════
# RAILWAY — Variables de entorno
# Bellsz Bot v1.0 [Liquidez Lateral]
# ══════════════════════════════════════════════════════════════
# Cómo usarlas:
#   Railway → tu proyecto → Variables → "Add Variable"
#   O importar con: railway variables set --from .env
# ══════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────
# OBLIGATORIAS — sin estas el bot no arranca
# ─────────────────────────────────────────────────────────────
BINGX_API_KEY=TU_API_KEY_AQUI
BINGX_SECRET_KEY=TU_SECRET_KEY_AQUI
TELEGRAM_TOKEN=TU_TOKEN_BOT_TELEGRAM
TELEGRAM_CHAT_ID=TU_CHAT_ID

# ─────────────────────────────────────────────────────────────
# EXCHANGE Y MODO
# ─────────────────────────────────────────────────────────────
LEVERAGE=10
MODO_DEMO=false

# ─────────────────────────────────────────────────────────────
# MEMORIA Y PERSISTENCIA
# ─────────────────────────────────────────────────────────────
MEMORY_DIR=/app/data

# ─────────────────────────────────────────────────────────────
# TAMAÑO DE POSICIÓN
# ─────────────────────────────────────────────────────────────
TRADE_USDT_BASE=10
TRADE_USDT_MAX=100

# ─────────────────────────────────────────────────────────────
# COMPOUNDING
# ─────────────────────────────────────────────────────────────
COMPOUND_STEP_USDT=50
COMPOUND_ADD_USDT=5

# ─────────────────────────────────────────────────────────────
# TIMEFRAMES
# ─────────────────────────────────────────────────────────────
TIMEFRAME=5m
CANDLES_LIMIT=200
MTF_ACTIVO=true
MTF_TIMEFRAME=1h
MTF_CANDLES=100
MTF_4H_ACTIVO=true

# ─────────────────────────────────────────────────────────────
# ESTRATEGIA BELLSZ — NÚCLEO (ajustar tras backtest)
# ─────────────────────────────────────────────────────────────
LIQ_LOOKBACK=50
LIQ_MARGEN=0.001
LIQ_MOSTRAR_H1=true
LIQ_MOSTRAR_H4=true
LIQ_MOSTRAR_D=true

# ─────────────────────────────────────────────────────────────
# INDICADORES
# ─────────────────────────────────────────────────────────────
EMA_FAST=9
EMA_SLOW=21
EMA_LOCAL_FAST=9
EMA_LOCAL_SLOW=21
ATR_PERIOD=14
RSI_PERIOD=14
RSI_BUY_MAX=70
RSI_SELL_MIN=30
VWAP_ACTIVO=true
VWAP_PCT=0.3

# ─────────────────────────────────────────────────────────────
# SL / TP — AJUSTAR CON RESULTADO DEL BACKTEST
# ─────────────────────────────────────────────────────────────
SL_ATR_MULT=1.5
TP_DIST_MULT=3.0
TP1_DIST_MULT=1.5
PARTIAL_TP1_MULT=1.5
MIN_RR=2.0

# ─────────────────────────────────────────────────────────────
# TRAILING STOP Y BREAK-EVEN
# ─────────────────────────────────────────────────────────────
TRAILING_ACTIVO=true
TRAILING_ACTIVAR=1.5
TRAILING_DISTANCIA=1.0
PARTIAL_TP_ACTIVO=true
BE_ACTIVO=true
BE_TRIGGER_ATR=1.0

# ─────────────────────────────────────────────────────────────
# TIME EXIT
# ─────────────────────────────────────────────────────────────
TIME_EXIT_HORAS=8.0

# ─────────────────────────────────────────────────────────────
# SCORING Y POSICIONES — AJUSTAR CON RESULTADO DEL BACKTEST
# ─────────────────────────────────────────────────────────────
SCORE_MIN=5
MAX_POSICIONES=3

# ─────────────────────────────────────────────────────────────
# COOLDOWN Y CIRCUIT BREAKER
# ─────────────────────────────────────────────────────────────
COOLDOWN_VELAS=5
MAX_PERDIDA_DIA=30.0

# ─────────────────────────────────────────────────────────────
# FILTROS SMC ADICIONALES
# ─────────────────────────────────────────────────────────────
OB_ACTIVO=true
OB_LOOKBACK=20
BOS_ACTIVO=true
FVG_ACTIVO=true
SWEEP_ACTIVO=true
SWEEP_LOOKBACK=20
DISPLACEMENT_ACTIVO=true
PREMIUM_DISCOUNT_ACTIVO=true
PREMIUM_DISCOUNT_LB=50
CORRELACION_ACTIVO=true
ASIA_RANGE_ACTIVO=true
VELA_CONFIRMACION=true
PINBAR_RATIO=0.50
RANGE_ACTIVO=false

# ─────────────────────────────────────────────────────────────
# EQUAL HIGHS / LOWS Y PIVOTES
# ─────────────────────────────────────────────────────────────
EQ_LOOKBACK=50
EQ_PIVOT_LEN=5
EQ_THRESHOLD=0.1
PIVOT_NEAR_PCT=0.3

# ─────────────────────────────────────────────────────────────
# KILL ZONES (minutos desde 00:00 UTC)
# ─────────────────────────────────────────────────────────────
KZ_ASIA_START=0
KZ_ASIA_END=240
KZ_LONDON_START=480
KZ_LONDON_END=720
KZ_NY_START=780
KZ_NY_END=960

# ─────────────────────────────────────────────────────────────
# PARES
# ─────────────────────────────────────────────────────────────
SOLO_LONG=false
PARES_BLOQUEADOS=
VOLUMEN_MIN_24H=5000000
MAX_PARES_SCAN=60

# ─────────────────────────────────────────────────────────────
# LOOP Y CONCURRENCIA
# ─────────────────────────────────────────────────────────────
LOOP_SECONDS=60
ANALISIS_WORKERS=4

# ─────────────────────────────────────────────────────────────
# METACLAW — IA validación de señales (opcional)
# ─────────────────────────────────────────────────────────────
METACLAW_ACTIVO=false
METACLAW_VETO_MINIMO=7
# ANTHROPIC_API_KEY=TU_ANTHROPIC_KEY   ← descomentar si activas MetaClaw

# ─────────────────────────────────────────────────────────────
# VERSIÓN
# ─────────────────────────────────────────────────────────────
VERSION=Bellsz Bot v1.0 [Liquidez Lateral]
LOG_LEVEL=INFO
