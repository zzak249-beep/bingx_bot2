# ============================================================
# BOT FLOOP Pro v4-FIX — Variables de entorno
# IMPORTANTE: Nombres corregidos para coincidir con el código
# ============================================================

# API Keys BingX
BINGX_API_KEY=""
BINGX_API_SECRET=""

# Telegram
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# --- Trading general ---
AUTO_TRADING_ENABLED="true"
MAX_OPEN_TRADES="3"
MAX_POSITION_SIZE="7"
MIN_TRADE_USDT="7"
LEVERAGE="3"
CHECK_INTERVAL="120"

# --- Scoring ---
MIN_SCORE="9"

# --- TP / SL ---
TP_ATR_MULT="3.0"
SL_ATR_MULT="2.2"
TP_MIN_PCT="1.5"
TP_MAX_PCT="6.0"
SL_MIN_PCT="0.8"
SL_MAX_PCT="2.5"

# --- Trailing Stop ---
# NOTA: el código lee TRAILING_START_PCT y TRAILING_LOCK_PCT
# Se mantienen los nombres del código (el v4-FIX también acepta los aliases)
TRAILING_STOP_ENABLED="true"
TRAILING_START_PCT="1.0"
TRAILING_LOCK_PCT="70"

# --- Protección de pérdidas ---
# NOTA: sin el "%" — solo el número
MAX_LOSS_PCT="8"

# --- Cooldowns ---
COOLDOWN_AFTER_TP_MIN="20"
COOLDOWN_AFTER_SL_MIN="45"

# --- Filtros de mercado ---
MIN_VOLUME_24H="500000"
MAX_SYMBOLS_TO_ANALYZE="60"
BTC_FILTER_1H_PCT="1.5"
BTC_FILTER_4H_PCT="2.5"
MARKET_FILTER_ENABLED="true"
MARKET_FILTER_PCT="2.0"
MARKET_FILTER_MIN_BAD="3"

# --- Órdenes ---
USE_LIMIT_ORDERS="true"
ENABLE_LONGS="true"
ENABLE_SHORTS="true"
SL_LIMIT_OFFSET_PCT="0.05"

# --- FLOOP Core ---
FLOOP_SENSITIVITY="6"
FLOOP_ATR_LENGTH="14"
FLOOP_ATR_MULT="0.8"
FLOOP_EMA_FAST="60"
FLOOP_EMA_SLOW="200"
FLOOP_EMA_FILTER="true"
FLOOP_HTF_TF="1h"
FLOOP_ADX_FILTER="true"
FLOOP_ADX_THRESH="20"
FLOOP_CHOP_FILTER="true"
FLOOP_CHOP_THRESH="61.8"
FLOOP_COOLDOWN_BARS="5"
