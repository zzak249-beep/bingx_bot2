# ══════════════════════════════════════════════════
#  MLP Tactical Bridge Bot — Variables de Entorno
#  Configura estas variables en Railway → Variables
# ══════════════════════════════════════════════════

# ── API BingX (Futuros Perpetuos) ──────────────────
# Obtén tus claves en: BingX → Perfil → API Management
# Permisos necesarios: ✅ Trade  ✅ Read  ❌ Withdraw
BINGX_API_KEY=TU_API_KEY_AQUI
BINGX_SECRET_KEY=TU_SECRET_KEY_AQUI

# ── Telegram ───────────────────────────────────────
# Bot Token → habla con @BotFather en Telegram → /newbot
# Chat ID  → habla con @userinfobot para obtener tu ID
TELEGRAM_TOKEN=TU_BOT_TOKEN_AQUI
TELEGRAM_CHAT_ID=TU_CHAT_ID_AQUI

# ── Configuración de Trading ───────────────────────
SYMBOL=BTC-USDT          # Par: BTC-USDT, ETH-USDT, RUNE-USDT, etc.
TIMEFRAME=1h             # 1m 3m 5m 15m 30m 1h 2h 4h 1d
TRADE_AMOUNT=10          # USDT por operación (sin apalancamiento)
LEVERAGE=5               # Apalancamiento (1-50)
MAX_RISK_PCT=2           # % máximo de balance a arriesgar
MIN_SIGNAL=2             # Señal mínima requerida: 2 (conservador) o 3 (estricto)

# ── Modo de operación ──────────────────────────────
# ⚠️  IMPORTANTE: Empieza con false para probar sin dinero real
# Solo cambia a true cuando hayas verificado que todo funciona
USE_LIVE=false
