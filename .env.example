# BingX API Credentials
BINGX_API_KEY=your_bingx_api_key_here
BINGX_API_SECRET=your_bingx_api_secret_here

# Telegram Notifications
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Trading Configuration - MULTI-PAR
# Lista de pares separados por coma (sin espacios)
# Ejemplos de configuración:

# Conservador (3 pares principales)
SYMBOLS=BTC-USDT,ETH-USDT,SOL-USDT

# Moderado (10 pares) - RECOMENDADO
# SYMBOLS=BTC-USDT,ETH-USDT,SOL-USDT,BNB-USDT,XRP-USDT,ADA-USDT,AVAX-USDT,MATIC-USDT,LINK-USDT,DOT-USDT

# Agresivo (20 pares)
# SYMBOLS=BTC-USDT,ETH-USDT,SOL-USDT,BNB-USDT,XRP-USDT,ADA-USDT,DOGE-USDT,AVAX-USDT,DOT-USDT,MATIC-USDT,LINK-USDT,UNI-USDT,ATOM-USDT,ARB-USDT,OP-USDT,APT-USDT,NEAR-USDT,FTM-USDT,INJ-USDT,TIA-USDT

# Todos los pares (50+ pares) - Ver TRADING_PAIRS.md
# SYMBOLS=BTC-USDT,ETH-USDT,BNB-USDT,SOL-USDT,XRP-USDT,ADA-USDT,DOGE-USDT,AVAX-USDT,DOT-USDT,MATIC-USDT,LINK-USDT,UNI-USDT,ATOM-USDT,LTC-USDT,ETC-USDT,ARB-USDT,OP-USDT,APT-USDT,SUI-USDT,SEI-USDT,TIA-USDT,INJ-USDT,AAVE-USDT,MKR-USDT,CRV-USDT,COMP-USDT,SNX-USDT,SUSHI-USDT,AXS-USDT,SAND-USDT,MANA-USDT,GALA-USDT,IMX-USDT,FTM-USDT,NEAR-USDT,ALGO-USDT,ONE-USDT,CELO-USDT,SHIB-USDT,PEPE-USDT,FLOKI-USDT

# Timeframe (1m, 5m, 15m, 1h, 4h, 1d)
TIMEFRAME=15m

# Intervalo de chequeo en segundos
CHECK_INTERVAL=60

# Tamaño máximo por posición en USDT
MAX_POSITION_SIZE=100

# Número máximo de posiciones simultáneas
# Recomendado: 2-3 para conservador, 5 para moderado, 10+ para agresivo
MAX_POSITIONS=3

# Strategy Parameters (opcional - usa valores por defecto si no se especifica)
# LINREG_LENGTH=100
# LINREG_MULT=2.0
# RISK_REWARD=2.5

