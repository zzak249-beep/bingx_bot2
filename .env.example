# ═══════════════════════════════════════════════════════
#  GUA-USDT Bot v2 — Variables de Entorno
# ═══════════════════════════════════════════════════════

# ── BingX ──────────────────────────────────────────────
BINGX_API_KEY=tu_api_key_aqui
BINGX_SECRET=tu_secret_aqui

# ── Telegram ───────────────────────────────────────────
TELEGRAM_TOKEN=123456789:ABCDEfghijk...
TELEGRAM_CHAT_ID=-100123456789

# ── Modo ───────────────────────────────────────────────
MODE=SIGNAL     # SIGNAL | LIVE

# ── Símbolo y TFs ──────────────────────────────────────
SYMBOL=GUA-USDT
INTERVAL=3m
INTERVAL_TREND=15m
INTERVAL_MACRO=1h

# ── Capital ────────────────────────────────────────────
LEVERAGE=5
RISK_PCT=0.02
MAX_OPEN_TRADES=1

# ── ATR multipliers ────────────────────────────────────
ATR_SL_MULT=1.5
ATR_TP1_MULT=2.0
ATR_TP2_MULT=4.0
ATR_TRAIL_MULT=1.0
ATR_HIGHVOL_MULT=2.0    # SL ampliado en alta volatilidad

# ── RSI / ADX ──────────────────────────────────────────
RSI_OB=63
RSI_OS=37
ADX_MIN=18

# ── Señal ──────────────────────────────────────────────
SCORE_THR=0.58          # Más permisivo que v1 (más condiciones disponibles)

# ── SMC ────────────────────────────────────────────────
FVG_MIN_SIZE=0.003      # FVG mínimo 0.3%
LIQ_TOLERANCE=0.002     # Tolerancia equal highs/lows 0.2%

# ── RVOL ───────────────────────────────────────────────
RVOL_MIN=1.3            # 1.3x de volumen medio mínimo

# ── Funding extremos ───────────────────────────────────
FUNDING_EXTREME_LONG=0.0003
FUNDING_EXTREME_SHORT=-0.0003

# ── Sesiones ───────────────────────────────────────────
SESSION_FILTER=true     # Solo London (7-12 UTC) y NY (13-18 UTC)

# ── Cooldown ───────────────────────────────────────────
COOLDOWN_MIN=15

# ── Railway ────────────────────────────────────────────
PORT=8080
