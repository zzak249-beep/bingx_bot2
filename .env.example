# ══════════════════════════════════════════
#  Sniper Bot V26.1 - Variables de entorno
#  Copia este archivo como .env (local)
#  En Railway: añádelas en Variables > New Variable
# ══════════════════════════════════════════

# ── BingX API ─────────────────────────────
BINGX_API_KEY=tu_api_key_aqui
BINGX_API_SECRET=tu_api_secret_aqui

# ── Telegram ──────────────────────────────
TELEGRAM_TOKEN=123456789:ABCdef...
TELEGRAM_CHAT_ID=-100xxxxxxxxxx   # ID del grupo o tu chat ID personal

# ── Configuración del bot ─────────────────
SYMBOL=BTC-USDT          # Par a operar (BTC-USDT, ETH-USDT, SOL-USDT...)
TIMEFRAME=15m             # Vela: 1m 3m 5m 15m 1h 4h 1d
LEVERAGE=5                # Apalancamiento (5-10 recomendado)
MAX_RISK_PCT=1.0          # % del balance a arriesgar por trade (1% = conservador)
