# QF×JP Bot v3.4 — Environment Variables
# Copy this to Railway Variables section

# ── REQUIRED ──────────────────────────────────────────────────────────
BINGX_API_KEY=your_api_key_here
BINGX_API_SECRET=your_api_secret_here
TELEGRAM_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ── TRADING MODE ──────────────────────────────────────────────────────
TESTNET=false              # true = paper trading on BingX testnet
AUTO_TRADE=false           # true = execute real orders automatically

# ── CAPITAL & RISK ────────────────────────────────────────────────────
CAPITAL=1000               # Total capital in USDT
RISK_PCT=1.0               # % risk per trade
MAX_POS_PCT=0.05           # Max 5% of capital per position
MAX_POSITIONS=5            # Max concurrent open positions
MAX_DAILY_LOSS=3.0         # Stop trading if daily loss exceeds 3%
MAX_DAILY_TRADES=20        # Max trades per day
LEVERAGE=5                 # Default leverage

# ── SIGNAL QUALITY ────────────────────────────────────────────────────
MIN_SIGNAL=FUEL            # Minimum signal for auto-trade: STD / FUEL / SUP
THR_STD=55                 # Score threshold for STD signal
THR_FUEL=68                # Score threshold for FUEL signal
THR_SUP=80                 # Score threshold for SUPREMA signal
HTF_MIN=2                  # Minimum HTF timeframes aligned (0-3)

# ── SCANNER ───────────────────────────────────────────────────────────
SCAN_INTERVAL=30           # Seconds between full scans
MAX_CONCURRENT=15          # Max concurrent API requests
MIN_VOLUME=500000          # Minimum 24h volume in USDT to consider symbol

# ── KELLY CRITERION ───────────────────────────────────────────────────
KEL_WIN=0.55               # Estimated win rate (0-1)
KEL_RR=1.8                 # Estimated R:R ratio
KEL_FRAC=0.25              # Kelly fraction (0.25 = quarter Kelly — safer)
