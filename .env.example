# ══════════════════════════════════════════════════════
# BOT FUSION v2.0.0 — Multi-Timeframe + ATR Dinámico
# ══════════════════════════════════════════════════════

# ─── BingX API ────────────────────────────────────────
BINGX_API_KEY=tu_api_key_aqui
BINGX_API_SECRET=tu_api_secret_aqui

# ─── Telegram ─────────────────────────────────────────
TELEGRAM_BOT_TOKEN=tu_token_aqui
TELEGRAM_CHAT_ID=tu_chat_id_aqui

# ─── Trading ──────────────────────────────────────────
AUTO_TRADING_ENABLED=true
MAX_POSITION_SIZE=7
MIN_TRADE_USDT=5
LEVERAGE=3
MAX_OPEN_TRADES=3
TRAILING_STOP_ENABLED=true
USE_LIMIT_ORDERS=true

# ─── Direcciones ──────────────────────────────────────
ENABLE_LONGS=true
ENABLE_SHORTS=true

# ─── TP/SL Dinámico con ATR ───────────────────────────
TP_ATR_MULTIPLIER=2.5
SL_ATR_MULTIPLIER=1.0
TP_MIN_PCT=1.5
TP_MAX_PCT=5.0
SL_MIN_PCT=0.8
SL_MAX_PCT=2.0

# ─── Filtros ──────────────────────────────────────────
MIN_SCORE=65
MIN_VOLUME_24H=500000
MAX_SYMBOLS_TO_ANALYZE=60
BTC_FILTER_PCT=2.0
CHECK_INTERVAL=120

# ─── Trend Magic ──────────────────────────────────────
CCI_LENGTH=20
ATR_LENGTH=5
ATR_MULTIPLIER=1.0

# ─── RMI Trend Sniper ─────────────────────────────────
RMI_LENGTH=14
RMI_POSITIVE=66
RMI_NEGATIVE=30
